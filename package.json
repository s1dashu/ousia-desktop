{
  "name": "ousia-desktop",
  "version": "0.1.3",
  "description": "A simplified Electron desktop client for Pi coding agent sessions.",
  "license": "MIT",
  "homepage": "https://github.com/s1dashu/ousia-desktop#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/s1dashu/ousia-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/s1dashu/ousia-desktop/issues"
  },
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "dev": "npm start",
    "desktop:dev": "npm start",
    "renderer:dev": "vite --config vite.renderer.config.ts",
    "package": "node scripts/package-app.cjs",
    "package:forge": "electron-forge package",
    "make": "npm run make:dmg",
    "make:dmg": "node scripts/make-dmg.cjs",
    "make:dmg:signed": "node scripts/make-dmg-signed.cjs",
    "notarize:dmg": "node scripts/notarize-dmg.cjs",
    "make:dmg:notarized": "node scripts/make-dmg-notarized.cjs",
    "make:forge": "electron-forge make",
    "publish": "electron-forge publish",
    "build": "tsc -b && NODE_OPTIONS=--max-old-space-size=8192 electron-forge package",
    "lint": "eslint .",
    "check": "npm run typecheck && npm run lint",
    "audit:prod": "npm audit --omit=dev --registry=https://registry.npmjs.org/",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "preview": "vite preview --config vite.renderer.config.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@earendil-works/pi-ai": "^0.79.7",
    "@earendil-works/pi-coding-agent": "^0.79.7",
    "@hugeicons/core-free-icons": "^4.2.1",
    "@hugeicons/react": "^1.1.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.4.1",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^16.5.0",
    "prettier": "^3.8.4",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^7.3.5"
  },
  "overrides": {
    "dompurify": "3.4.11",
    "hono": "4.12.26",
    "protobufjs": "7.6.4",
    "undici": "8.5.0",
    "ws": "8.21.0"
  }
}
